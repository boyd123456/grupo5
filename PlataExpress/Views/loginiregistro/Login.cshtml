    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model PlataExpress.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow rounded-4">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Iniciar Sesión</h2>

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Mensaje"]
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NombreDeUsuario" class="form-label"></label>
                            <input asp-for="NombreDeUsuario" class="form-control" />
                            <span asp-validation-for="NombreDeUsuario" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ClaveDeUsuario" class="form-label"></label>
                            <input asp-for="ClaveDeUsuario" class="form-control" />
                            <span asp-validation-for="ClaveDeUsuario" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Ingresar</button>

                        <div class="text-center mt-3">
                            <a asp-controller="Account" asp-action="Register">¿No tienes cuenta? Regístrate</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}