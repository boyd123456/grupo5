@model DashboardViewModel
@if (TempData["mensaje"] != null)
{
    <div class="alert alert-success text-center">
        @TempData["mensaje"]
    </div>
}
<style>
    .card {
        border-radius: 20px;
        transition: 0.3s;
    }

    .page-container {
        margin-bottom: 100px;
    }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

    .btn {
        border-radius: 30px;
        padding: 10px 20px;
        font-weight: bold;
    }
    </style>
    @{
        ViewData["Title"] = "Panel de Usuario";
        var usuario = Context.Session.GetString("usuario");
    }

    <div class="container mt-4">

        <div class="p-4 mb-4 bg-light rounded shadow-sm">
            <h2>👋 Bienvenido @usuario</h2>
            <p>Desde aquí puedes gestionar tus envíos internacionales de forma rápida y segura.</p>
        </div>


        <div class="row text-center mb-4">

            <div class="col-md-4">
                <div class="card shadow p-3">
                <h3>@Model.TotalEnvios</h3>
                    <p>Envíos realizados</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow p-3">
                <h3>$@Model.TotalMonto</h3>
                    <p>Total enviado</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow p-3">
                <h3>@Model.EnProceso</h3>
                    <p>Operaciones en proceso</p>
                </div>
            </div>

        </div>

        <h4 class="mb-3">Operaciones</h4>

        <div class="row mb-5">

            <div class="col-md-4">
                <div class="card shadow-lg p-4 text-center">

                    <h4>💸 Enviar Dinero</h4>
                    <p>Realiza un nuevo envío internacional.</p>

                <a asp-controller="Remesa" asp-action="EnviarDinero"
                       class="btn btn-primary">Enviar dinero</a>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-lg p-4 text-center">

                    <h4>📄 Mis Envíos</h4>
                    <p>Consulta el historial de tus envíos.</p>

                <a asp-controller="Remesa" asp-action="MisEnvios"
                       class="btn btn-success">Ver envíos</a>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-lg p-4 text-center">

                    <h4>🔎 Estado</h4>
                    <p>Revisa el estado de tus operaciones.</p>

                    <a asp-controller="Usuario" asp-action="EstadoOperacion"
                       class="btn btn-warning">Consultar</a>

                </div>
            </div>

        </div>

        <h4 class="mb-3">Últimos envíos</h4>

        <table class="table table-bordered shadow">

            <tr>
                <th>Destinatario</th>
                <th>País</th>
                <th>Monto</th>
                <th>Estado</th>
            </tr>

        @foreach (var item in Model.UltimosEnvios)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Agencia</td>
                <td>$@item.Monto</td>
                <td>
                    @if (item.Estado == "Enviado")
                    {
                        <span class="badge bg-warning">En proceso</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Completado</span>
                    }
                </td>
            </tr>
        }


        </table>


        <!-- INFORMACION -->
        <div class="alert alert-info mt-4">

            💡 <strong>Consejo:</strong> Mantén tus datos actualizados para evitar retrasos en tus envíos internacionales.

        </div>

    </div>
