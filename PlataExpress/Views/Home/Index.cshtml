@using System.Globalization
@{
    ViewData["Title"] = "Inicio";

    decimal montoEnviarSoles = 1000m;
    decimal tipoCambio = 3.77m;
    bool destinoEnPeru = false;
    decimal comisionPorc = 0.03m;

    decimal montoComisionSoles = Math.Round(montoEnviarSoles * comisionPorc, 2);
    decimal montoDespuesComisionSoles = Math.Round(montoEnviarSoles - montoComisionSoles, 2);

    decimal montoRecibidoUSD = destinoEnPeru ? 0m : Math.Round(montoDespuesComisionSoles / tipoCambio, 2);

    string montoEnviarSolesText = montoEnviarSoles.ToString("N2", CultureInfo.InvariantCulture);
    string montoRecibidoUSDText = montoRecibidoUSD.ToString("N2", CultureInfo.InvariantCulture);
    string comisionText = montoComisionSoles.ToString("N2", CultureInfo.InvariantCulture);
}

<div class="hero pt-5 pb-5">
    <div class="container" style="max-width: 1300px;">
        <div class="row align-items-center">
            
            <div class="col-lg-7 pe-lg-5 mb-5 mb-lg-0">
                <h1 class="display-3 fw-bold mb-4" style="letter-spacing: -1.5px;">Envía dinero al exterior<br /><span class="gradient-text">de forma directa y rápida</span></h1>
                <p class="lead text-muted mb-4" style="font-size: 1.15rem; line-height: 1.7;">Realizamos transferencias internacionales mediante nuestros cajeros autorizados. Rápido, confiable y sin complicaciones para tus seres queridos en el extranjero.</p>

                <div class="d-flex flex-wrap gap-3 mt-4 mb-5">
                    <a class="btn btn-primary btn-lg px-4 py-3 fw-bold rounded-pill shadow-sm" asp-controller="loginYRegistro" asp-action="Register">
                        Crear cuenta gratis <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a class="btn btn-outline-dark btn-lg px-4 py-3 fw-bold rounded-pill" asp-controller="Home" asp-action="ComoFuncionamos">
                        Ver cómo funciona
                    </a>
                </div>

                <div class="d-flex gap-5 mt-4 pt-3 border-top">
                    <div>
                        <h4 class="fw-bold mb-0 text-dark">+50,000</h4>
                        <small class="text-muted fw-medium">Clientes activos</small>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0 text-dark">+120</h4>
                        <small class="text-muted fw-medium">Cajeros en Perú</small>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0 text-dark">+30</h4>
                        <small class="text-muted fw-medium">Países destino</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="hero-mockup-container">
                    <div class="floating-badge badge-security">
                        <div class="badge-icon">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h6 class="fw-bold mb-1">Seguridad nivel bancario</h6>
                        <p class="small text-muted mb-0">Cifrado de 256 bits</p>
                    </div>

                    <img src="~/img/app-mockup.png" 
                         alt="PlataExpress App" class="floating-mockup img-fluid" asp-append-version="true" />

                    <div class="floating-badge badge-speed">
                        <div class="badge-icon" style="background: #10b981;">
                            <i class="bi bi-lightning-fill"></i>
                        </div>
                        <h6 class="fw-bold mb-1">Envío instantáneo</h6>
                        <p class="small text-muted mb-0">Llega en segundos o en<br /> minutos depende del<br /> lugar de destino</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

