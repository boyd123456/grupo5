            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const sendAmountInput = document.getElementById("sendAmount");
        const targetCountrySelect = document.getElementById("targetCountry");
        const receiveAmountSpan = document.getElementById("receiveAmount");
        const receiveSymbolSpan = document.getElementById("receiveSymbol");
        const flagImg = document.getElementById("flagImg");
        const rateText = document.getElementById("rateText");
        const commissionText = document.getElementById("commissionText");

        const exchangeRates = {
            "USD": { rate: 3.77, type: "divide", symbol: "$", code: "USD", flag: "us" },
            "COP": { rate: 1020, type: "multiply", symbol: "$", code: "COP", flag: "co" },
            "EUR": { rate: 4.10, type: "divide", symbol: "€", code: "EUR", flag: "es" },
            "MXN": { rate: 4.35, type: "multiply", symbol: "$", code: "MXN", flag: "mx" },
            "CLP": { rate: 250, type: "multiply", symbol: "$", code: "CLP", flag: "cl" },
            "ARS": { rate: 260, type: "multiply", symbol: "$", code: "ARS", flag: "ar" }
        };

        const COMMISSION_RATE = 0.05; 

        function formatCurrency(amount) {
            return amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function calculate() {
            let amount = parseFloat(sendAmountInput.value);
            if (isNaN(amount) || amount <= 0) {
                receiveAmountSpan.textContent = "0.00";
                commissionText.textContent = "- S/ 0.00";
                return;
            }

            const country = targetCountrySelect.value;
            const data = exchangeRates[country];

            const commission = amount * COMMISSION_RATE;
            const amountToSend = amount - commission;
            
            let received = 0;
            if (data.type === "divide") {
                received = amountToSend / data.rate;
                rateText.textContent = `1 ${data.code} = S/ ${data.rate.toFixed(2)}`;
            } else {
                received = amountToSend * data.rate;
                rateText.textContent = `1 PEN = ${data.rate.toLocaleString()} ${data.code}`;
            }

            receiveAmountSpan.textContent = formatCurrency(received);
            receiveSymbolSpan.textContent = data.symbol;
            commissionText.textContent = `- S/ ${formatCurrency(commission)}`;
            flagImg.src = `https://flagcdn.com/w20/${data.flag}.png`;
        }

        sendAmountInput.addEventListener("input", calculate);
        targetCountrySelect.addEventListener("change", calculate);

        calculate();
    });
</script>
        </div>
    </div>
</div>

