@{
    ViewData["Title"] = "Destinos Internacionales";
}

<div class="destinos-page py-5 mt-4">
    <!-- Hero Section -->
    <div class="container mb-5 text-center">
        <span class="badge bg-success bg-opacity-10 text-success mb-3 px-3 py-2 rounded-pill fw-semibold">Cobertura Global</span>
        <h1 class="display-4 fw-bold text-dark mb-3" style="letter-spacing: -1px;">Llegamos a donde más nos <span class="text-primary">necesitan</span></h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">
            Plata Express te permite enviar dinero desde cualquier caja a nivel nacional en Perú hacia los destinos más importantes del mundo con total seguridad y rapidez.
        </p>
    </div>

    <!-- Destinations Grid -->
    <div class="container py-4">
        <div class="row g-4 justify-content-center">
            
            <!-- EE.UU. -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/us.png" alt="Bandera de EE.UU." class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">Estados Unidos</h4>
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Envío en Minutos</span>
                            <p class="text-muted small mb-0">Depósitos directos a las cuentas principales.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- España -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/es.png" alt="Bandera de España" class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">España</h4>
                            <span class="badge bg-danger bg-opacity-10 text-danger mb-2">Alta Demanda</span>
                            <p class="text-muted small mb-0">Apoyando a la comunidad peruana en Europa.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Colombia -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/co.png" alt="Bandera de Colombia" class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">Colombia</h4>
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Envío en Minutos</span>
                            <p class="text-muted small mb-0">Rápido y directo a entidades locales.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chile -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/cl.png" alt="Bandera de Chile" class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">Chile</h4>
                            <span class="badge bg-success bg-opacity-10 text-success mb-2">Cobertura Total</span>
                            <p class="text-muted small mb-0">Amplia red de cobro a nivel nacional.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Argentina -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/ar.png" alt="Bandera de Argentina" class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">Argentina</h4>
                            <span class="badge bg-warning bg-opacity-10 text-warning mb-2" style="color: #b45309 !important;">Mejores Tasas</span>
                            <p class="text-muted small mb-0">El tipo de cambio más favorable garantizado.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mexico -->
            <div class="col-lg-4 col-md-6">
                <div class="card destination-card h-100 border-0 shadow-sm" style="border-radius: 24px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;">
                    <div class="card-body p-4 d-flex align-items-center">
                        <img src="https://flagcdn.com/w80/mx.png" alt="Bandera de México" class="me-4 shadow-sm" style="width: 70px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);">
                        <div>
                            <h4 class="fw-bold mb-1">México</h4>
                            <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Envío en Minutos</span>
                            <p class="text-muted small mb-0">Facilitando las transacciones norteamericanas.</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Call to Action -->
    <div class="container mt-5 mb-5 text-center">
        <div class="card border-0 shadow-sm" style="border-radius: 24px; background: linear-gradient(to right, #f8fafc, #ffffff);">
            <div class="card-body p-5">
                <h3 class="fw-bold mb-3 text-dark">¿Tu destino no está en la lista?</h3>
                <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">Constantemente ampliamos nuestra red de operaciones internacionales. Regístrate en nuestra plataforma para explorar la lista completa y actualizada de países disponibles para tus giros.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="loginYRegistro" asp-action="Register" class="btn btn-primary px-5 py-3 fw-bold rounded-pill shadow-sm" style="transition: transform 0.2s; font-size: 16px;">
                        Descubrir más destinos <i class="bi bi-globe-americas ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .destination-card {
        border: 1px solid rgba(0,0,0,0.04) !important;
    }
    .destination-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 1.5rem 3rem rgba(0,0,0,.08) !important;
        border-color: rgba(59, 130, 246, 0.4) !important;
    }
</style>
