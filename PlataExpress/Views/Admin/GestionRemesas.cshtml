@model IEnumerable<PlataExpress.Models.Remesa>

@{
    ViewData["Title"] = "GestionRemesas";
}

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-4">
    <h2 class="mb-4">Gestión de Remesas</h2>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Nombre</th>
                <th>Agencia</th>
                <th>Monto + Comisión</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Acción</th>
                <th>Detalle</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.IdRemesa</td>
                    <td>@r.TipoOperacion</td>
                    <td>@r.Nombre</td>
                    <td>@r.Agencia</td>
                    <td>S/. @(r.Monto + r.Comision)</td>
                    <td>@r.FechaEnvio.ToShortDateString()</td>
                    <td>
                        <span class="badge bg-warning">@r.Estado</span>
                    </td>
                    <td>
                        <a asp-action="CambiarEstado" asp-route-id="@r.IdRemesa" class="btn btn-primary btn-sm">
                            Cambiar Estado
                        </a>
                    </td>
                    <td>
                        <a asp-action="Detalle" asp-route-id="@r.IdRemesa" class="btn btn-info btn-sm">
                            Ver
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>