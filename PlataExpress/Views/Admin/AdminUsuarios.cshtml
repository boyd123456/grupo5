@model IEnumerable<PlataExpress.Models.AdminUsuario>

@{
    ViewData["Title"] = "AdminUsuarios";
}

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<div class="container mt-4">
    <h2 class="mb-4">Gestión de Usuarios</h2>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Fecha Registro</th>
                <th>Última Conexión</th>
                <th>Inactividad</th>
                <th>Estado</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var diasInactivo = (DateTime.Now - user.UltimaConexion).Days;

                <tr>
                    <td>@user.IdAdmin</td>
                    <td>@user.Nombre</td>
                    <td>@user.Apellido</td>
                    <td>@user.FechaRegistro.ToShortDateString()</td>
                    <td>@user.UltimaConexion.ToShortDateString()</td>
                    <td>@diasInactivo días</td>
                    <td>
                        @if (user.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Desactivado</span>
                        }
                    </td>
                    <td>
                        @if (user.Activo)
                        {
                            <a asp-action="Desactivar" asp-route-id="@user.IdAdmin" class="btn btn-danger btn-sm">Desactivar</a>
                        }
                        else
                        {
                            <a asp-action="Activar" asp-route-id="@user.IdAdmin" class="btn btn-success btn-sm">Activar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>