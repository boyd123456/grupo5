@model IEnumerable<PlataExpress.Models.Remesa>

@{
    ViewData["Title"] = "Realizados";
}

<h2>Envíos Realizados</h2>

<table class="table table-dark table-striped mt-3">
    <thead>
        <tr>
            <th>ID</th>
            <th>Usuario</th>
            <th>Monto</th>
            <th>Fecha</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.IdRemesa</td>
                <td>@r.Nombre</td>
                <td>S/ @r.Monto</td>
                <td>@r.FechaEnvio</td>
            </tr>
        }
    </tbody>
</table>